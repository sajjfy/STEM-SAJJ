{
  "name": "sajj-stem",
  "version": "2.2.0",
  "description": "Comprehensive STEM expert plugin — 60+ skills across Physics, Quantum Computing, Chemistry, Biology, Mathematics, Engineering, Design, Data Science, and Scientific Research",
  "author": {
    "name": "sajjfy"
  },
  "homepage": "https://github.com/sajjfy/STEM-SAJJ",
  "repository": "https://github.com/sajjfy/STEM-SAJJ",
  "license": "MIT",
  "keywords": [
    "stem",
    "physics",
    "mathematics",
    "chemistry",
    "biology",
    "quantum",
    "engineering",
    "data-science",
    "research",
    "astropy",
    "qiskit",
    "cirq",
    "pennylane",
    "rdkit",
    "biopython",
    "sympy",
    "pymc",
    "lean4",
    "formal-methods"
  ],
  "skills": "./skills",
  "commands": "./commands",
  "mcp": "./.mcp.json",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "cd ${CLAUDE_PLUGIN_ROOT}/mcp-server && npm install --silent 2>/dev/null || true"
          },
          {
            "type": "command",
            "command": "echo 'sajj-stem v2.2.0 loaded (60+ STEM skills, 9 domains, MCP server ready). Use /sajj-stem to activate.'"
          }
        ]
      }
    ]
  }
}
